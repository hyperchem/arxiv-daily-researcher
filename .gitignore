# Python
__pycache__/
*.py[cod]
*.so

# Virtual Environment
venv/
.venv/

# IDE
.idea/
.vscode/
*.code-workspace

# Environment variables
.env
.env.local
!.env.example

# Logs
logs/
*.log

# Data (runtime generated)
# 使用 data/* 而非 data/，以便后续 ! 例外可以重新包含子目录
data/*
# 例外：topic-discovery 历史需要持久化，由 workflow 提交回仓库
!data/topic_discovery_history/
!data/topic_discovery_history/**

# Database
*.db-journal
*.db-wal
*.db-shm

# OS
.DS_Store
Thumbs.db
*:Zone.Identifier

# Temp
*.bak
*.tmp
*.swp
*~

# test
test/